<article class="group/card relative flex flex-col border border-B/60 rounded-sm overflow-hidden transition-all duration-700 ease-[cubic-bezier(0.25,1,0.5,1)] flex-1 group-has-[:hover]/gallery:flex-[0.25] hover:!flex-[3] _shadow-lg bg-transparent">
    
    <div class="relative w-full flex-1 bg-neutral-100 overflow-hidden">
        {{#if images}}
            {{#with (splitToArray images) as |imgArray|}}
                <div class="relative w-full h-full overflow-hidden">
                    {{#each imgArray}}
                        <img 
                            src="{{this}}" 
                            alt="{{../title}}" 
                            class="absolute inset-0 w-full h-full object-cover gallery-img transition-transform duration-300 {{#if @first}}opacity-100 z-10{{else}}opacity-0 z-0{{/if}}"
                            style="--img-idx: {{@index}};"
                            loading="lazy" 
                        />
                    {{/each}}
                </div>
                <div class="absolute w-3 h-3 bg-lime-400 bottom-4 right-4 group-hover/card:animate-ping z-20"></div>
                
                <style>
                    @keyframes energetic-pop-{{imgArray.length}} {
                        0% { opacity: 0; z-index: 10; transform: scale(1); }
                        0.5% { opacity: 1; z-index: 20; transform: scale(1); }
                        calc(100% / {{imgArray.length}}) { opacity: 1; z-index: 20; transform: scale(1.12); }
                        calc((100% / {{imgArray.length}}) + 0.5%) { opacity: 0; z-index: 10; transform: scale(1); }
                        100% { opacity: 0; z-index: 10; transform: scale(1); }
                    }
                    .group\/card:hover .gallery-img {
                        animation: energetic-pop-{{imgArray.length}} calc({{imgArray.length}} * 2.5s) infinite linear;
                        animation-delay: calc(var(--img-idx) * 2.5s);
                    }
                </style>
            {{/with}}

        {{else if img}}
            <img 
                src="{{img}}" 
                alt="{{title}}" 
                class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover/card:scale-105"
                loading="lazy"
            />
            <div class="absolute w-3 h-3 bg-lime-400 bottom-4 right-4 group-hover/card:animate-ping"></div>
        {{else}}
            <div class="w-full h-full flex items-center justify-center font-mono text-[10px] text-neutral-400 select-none">
                [ NO_IMAGE_ASSET ]
            </div>
        {{/if}}
    </div>

    <div class="grid transition-all duration-700 ease-[cubic-bezier(0.25,1,0.5,1)] grid-rows-[1fr] group-has-[:hover]/gallery:grid-rows-[0fr] group-hover/card:!grid-rows-[1fr] h-1/4 group-has-[:hover]/gallery:h-0 group-hover/card:!h-1/3">
        <div class="overflow-hidden">
            <div class="flex flex-col p-5 space-y-2 z-10">
                {{#if title}}
                    <h3 class="text-3xl tracking-tight text-B font-helvetica font-bold _whitespace-nowrap max-w-[150px] ">
                        {{title}}
                    </h3>
                {{/if}}
                
                {{#if desc}}
                    <div class="overflow-hidden py-1">
                        <p class="text-sm leading-relaxed text-neutral-500 font-helvetica truncate transition-all duration-500 ease-[cubic-bezier(0.25,1,0.5,1)] translate-y-full opacity-0 group-hover/card:translate-y-0 group-hover/card:opacity-100 w-full">
                            {{desc}}
                        </p>
                    </div>
                {{/if}}
            </div>
        </div>
    </div>
</article>
