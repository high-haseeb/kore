<a href="{{#if url}}{{url}}{{else}}#{{/if}}" class="group relative inline-block py-2 tracking-tight font-sans text-2xl font-medium text-white select-none cursor-pointer">

    <div class="relative overflow-hidden flex h-8">
        <span class="relative inline-block transition-transform duration-500 ease-[cubic-bezier(0.25,1,0.5,1)] group-hover:-translate-y-full after:content-[attr(data-text)] after:absolute after:top-full after:left-0 after:text-lime-400" data-text="{{text}}">
<span class="flex">
        {{#if text}}
            {{{staggerText text}}}
        {{/if}}
    </span>
        </span>
    </div>

    <span class="absolute bottom-0 left-0 w-full h-[4px] bg-lime-400 scale-x-0 origin-left transition-transform duration-500 ease-[cubic-bezier(0.25,1,0.5,1)] group-hover:scale-x-100"></span>

</a>
